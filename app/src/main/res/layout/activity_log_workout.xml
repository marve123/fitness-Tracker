<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:elevation="0dp">
        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/surface_dark"
            app:navigationIcon="@drawable/ic_back"
            app:navigationIconTint="@color/text_primary"
            app:title="Log Workout"
            app:titleTextColor="@color/accent_orange"/>
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- ── Workout Type ──────────────────────────────────────────── -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardBackgroundColor="@color/surface_dark"
                app:cardCornerRadius="14dp"
                app:cardElevation="3dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Workout Type"
                        android:textColor="@color/accent_orange"
                        android:textSize="12sp"
                        android:fontFamily="sans-serif-medium"
                        android:layout_marginBottom="8dp"/>
                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="e.g. Running, Cycling, Gym"
                        app:boxStrokeColor="@color/accent_orange"
                        app:hintTextColor="@color/text_secondary"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/et_workout_type"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="textCapWords"
                            android:textColor="@color/text_primary"
                            android:maxLength="50"/>
                    </com.google.android.material.textfield.TextInputLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ── Intensity Spinner ─────────────────────────────────────── -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardBackgroundColor="@color/surface_dark"
                app:cardCornerRadius="14dp"
                app:cardElevation="3dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Intensity Level"
                        android:textColor="@color/accent_orange"
                        android:textSize="12sp"
                        android:fontFamily="sans-serif-medium"
                        android:layout_marginBottom="8dp"/>
                    <Spinner
                        android:id="@+id/spinner_intensity"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:background="@drawable/spinner_bg"
                        android:popupBackground="@color/surface_dark"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ── Calorie Mode Selector ─────────────────────────────────── -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardBackgroundColor="@color/surface_dark"
                app:cardCornerRadius="14dp"
                app:cardElevation="3dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Calorie Mode"
                        android:textColor="@color/accent_orange"
                        android:textSize="12sp"
                        android:fontFamily="sans-serif-medium"
                        android:layout_marginBottom="12dp"/>

                    <RadioGroup
                        android:id="@+id/rg_mode"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <!-- Mode 1: Manual -->
                        <RadioButton
                            android:id="@+id/rb_manual"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="✏️  Manual  — enter duration + calories yourself"
                            android:textColor="@color/text_primary"
                            android:textSize="13sp"
                            android:checked="true"
                            android:buttonTint="@color/accent_orange"
                            android:layout_marginBottom="8dp"/>

                        <!-- Mode 2: Automatic -->
                        <RadioButton
                            android:id="@+id/rb_automatic"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="⚡  Automatic  — enter duration, calories calculated"
                            android:textColor="@color/text_primary"
                            android:textSize="13sp"
                            android:buttonTint="@color/accent_blue"
                            android:layout_marginBottom="8dp"/>
                    </RadioGroup>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ── Duration Field ────────────────────────────────────────── -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardBackgroundColor="@color/surface_dark"
                app:cardCornerRadius="14dp"
                app:cardElevation="3dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/til_duration"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Duration (minutes)"
                        app:boxStrokeColor="@color/accent_orange"
                        app:hintTextColor="@color/text_secondary"
                        app:suffixText="min"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/et_duration"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="number"
                            android:textColor="@color/text_primary"
                            android:maxLength="3"/>
                    </com.google.android.material.textfield.TextInputLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ── Calories Field ────────────────────────────────────────── -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardBackgroundColor="@color/surface_dark"
                app:cardCornerRadius="14dp"
                app:cardElevation="3dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/til_calories"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Calories Burned (kcal)"
                        app:boxStrokeColor="@color/accent_orange"
                        app:hintTextColor="@color/text_secondary"
                        app:suffixText="kcal"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/et_calories"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="numberDecimal"
                            android:textColor="@color/text_primary"/>
                    </com.google.android.material.textfield.TextInputLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ── Live Calculated Result ────────────────────────────────── -->
            <TextView
                android:id="@+id/tv_calculated_result"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="@color/accent_orange"
                android:textSize="14sp"
                android:fontFamily="sans-serif-medium"
                android:padding="14dp"
                android:background="@drawable/preview_bg"
                android:visibility="gone"
                android:layout_marginBottom="16dp"/>

            <!-- ── Save Button ───────────────────────────────────────────── -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_save_workout"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="SAVE WORKOUT &amp; START TIMER ⏱"
                android:textSize="14sp"
                android:fontFamily="sans-serif-medium"
                android:layout_marginBottom="24dp"
                app:backgroundTint="@color/accent_orange"
                app:cornerRadius="14dp"/>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
